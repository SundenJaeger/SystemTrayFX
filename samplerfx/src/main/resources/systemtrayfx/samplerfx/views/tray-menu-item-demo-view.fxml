<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="systemtrayfx.samplerfx.controller.TrayMenuItemDemoController">
   <content>
      <VBox spacing="10.0">
         <children>
            <GridPane vgap="5.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints vgrow="SOMETIMES" />
                  <RowConstraints vgrow="SOMETIMES" />
                  <RowConstraints vgrow="SOMETIMES" />
                  <RowConstraints vgrow="SOMETIMES" />
                  <RowConstraints vgrow="SOMETIMES" />
                  <RowConstraints vgrow="SOMETIMES" />
                  <RowConstraints vgrow="SOMETIMES" />
                  <RowConstraints vgrow="SOMETIMES" />
               </rowConstraints>
               <children>
                  <VBox GridPane.columnSpan="2147483647">
                     <children>
                        <HBox spacing="5.0">
                           <children>
                              <Label text="TrayMenuItem">
                                 <font>
                                    <Font name="Segoe UI Semibold" size="30.0" />
                                 </font>
                              </Label>
                           </children>
                        </HBox>
                        <Label text="Base class for all system tray menu items." wrapText="true">
                           <font>
                              <Font name="Segoe UI Semilight" size="15.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
                  <Label text="Properties" GridPane.rowIndex="4">
                     <font>
                        <Font name="Segoe UI Semibold" size="20.0" />
                     </font>
                  </Label>
                  <VBox spacing="5.0" GridPane.halignment="RIGHT" GridPane.rowIndex="5">
                     <children>
                        <CheckBox fx:id="isDisabledCheckBox" mnemonicParsing="false" text="isDisabled">
                           <font>
                              <Font name="Segoe UI Semilight" size="14.0" />
                           </font>
                           <tooltip>
                              <Tooltip text="Setting this to true will make the stage not exit." />
                           </tooltip>
                        </CheckBox>
                        <Separator />
                        <VBox spacing="5.0">
                           <children>
                              <Label text="TextProperty">
                                 <font>
                                    <Font name="Segoe UI Semilight" size="15.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="textPropertyTextField" maxHeight="-Infinity" text="Sample TrayMenuItem" />
                           </children>
                        </VBox>
                        <Separator />
                        <VBox spacing="5.0">
                           <children>
                              <Label text="ImageProperty">
                                 <font>
                                    <Font name="Segoe UI Semilight" size="15.0" />
                                 </font>
                              </Label>
                              <HBox>
                                 <children>
                                    <Button fx:id="chooseImageButton" mnemonicParsing="false" onAction="#chooseImage" text="Choose Image" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  <Label text="Preview" GridPane.rowIndex="1">
                     <font>
                        <Font name="Segoe UI Semibold" size="20.0" />
                     </font>
                  </Label>
                  <ImageView cache="true" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" GridPane.rowIndex="2">
                     <image>
                        <Image url="@../media/tray-menu-item-demo.gif" />
                     </image>
                  </ImageView>
                  <Accordion GridPane.rowIndex="6">
                     <panes>
                        <TitledPane animated="false" text="Source Code">
                           <content>
                              <TextArea editable="false" prefHeight="120.0" prefWidth="200.0" text="TrayMenuItem trayMenuItem = new TrayMenuItem(&quot;Sample TrayMenuItem&quot;);&#10;&#10;trayMenuItem.disableProperty().bind(selectedProperty);&#10;trayMenuItem.textProperty().bind(textProperty);&#10;trayMenuItem.setImage(image);" />
                           </content>
                        </TitledPane>
                     </panes>
                  </Accordion>
                  <HBox spacing="5.0" GridPane.rowIndex="3">
                     <children>
                        <Label text="Number of clicks:">
                           <font>
                              <Font name="Segoe UI Semilight" size="15.0" />
                           </font>
                        </Label>
                        <Label fx:id="numberOfClicksLabel" text="Label">
                           <font>
                              <Font name="Segoe UI Semilight" size="15.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
               </children>
            </GridPane>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </content>
</ScrollPane>
