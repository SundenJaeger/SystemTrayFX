<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.systemtray.samplerfx.controller.MenuItemsController">
   <top>
      <VBox BorderPane.alignment="TOP_LEFT">
         <children>
            <Label text="Menu Items">
               <font>
                  <Font name="Segoe UI Semibold" size="30.0" />
               </font>
            </Label>
            <Label text="SystemTrayFX various menu items." wrapText="true">
               <font>
                  <Font name="Segoe UI Semilight" size="15.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </top>
   <center>
      <VBox spacing="5.0" BorderPane.alignment="TOP_LEFT">
         <children>
            <Button mnemonicParsing="false" onAction="#toTrayMenuItem" text="TrayMenuItem" />
            <Button mnemonicParsing="false" onAction="#toTrayExitMenuItem" text="TrayExitMenuItem" />
            <Button mnemonicParsing="false" onAction="#toTrayCheckMenuItem" text="TrayCheckMenuItem" />
            <Button mnemonicParsing="false" onAction="#toTrayMenu" text="TrayMenu" />
            <Button mnemonicParsing="false" onAction="#toFXMenuItemWrapper" text="FXMenuItemWrapper" />
            <Button mnemonicParsing="false" onAction="#toSeparator" text="Separator" />
         </children>
         <BorderPane.margin>
            <Insets top="10.0" />
         </BorderPane.margin>
      </VBox>
   </center>
   <padding>
      <Insets left="10.0" />
   </padding>
</BorderPane>
